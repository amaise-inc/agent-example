# IntelliJ IDEA — whitelist shared project config only
!/.idea/
/.idea/*
!/.idea/.gitignore
!/.idea/compiler.xml
!/.idea/encodings.xml
!/.idea/google-java-format.xml
!/.idea/jarRepositories.xml
!/.idea/misc.xml
!/.idea/vcs.xml
# example app config and data
example/.env
example/agent.env
example/data/grafana/*
example/data/squid_logs/*
# example PDFs
pdfs/*.pdf
temp/*.pdf
